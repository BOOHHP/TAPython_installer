<Window x:Class="TAPythonInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="TAPython 快速安装器"
        Icon="Assets/AppIcon.ico"
        Width="1120" Height="760"
        MinWidth="920" MinHeight="660"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0B0F18">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="58"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="22" ShadowDepth="0" Color="#000000" Opacity="0.34"/>

        <SolidColorBrush x:Key="PageBackground" Color="#0B0F18"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#202638"/>
        <SolidColorBrush x:Key="PanelStroke" Color="#333B52"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AEB7CB"/>
        <SolidColorBrush x:Key="TextMuted" Color="#798399"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#6EA2FF"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#5DE2FF"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FF9A5E"/>

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#28324A" Offset="0"/>
            <GradientStop Color="#182033" Offset="0.55"/>
            <GradientStop Color="#111827" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#78A8FF" Offset="0"/>
            <GradientStop Color="#4778FF" Offset="0.62"/>
            <GradientStop Color="#59D9FF" Offset="1"/>
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="GlowBrush" Center="0.52,0.26" GradientOrigin="0.52,0.26" RadiusX="0.8" RadiusY="0.65">
            <GradientStop Color="#355CFF" Offset="0"/>
            <GradientStop Color="#22345F" Offset="0.38"/>
            <GradientStop Color="#111827" Offset="1"/>
        </RadialGradientBrush>

        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>

        <Style x:Key="MetricCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A2031"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentCyan}"/>
            <Setter Property="BorderBrush" Value="#3A435B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SelectionBrush" Value="#4D6EA2FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="#20283D"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#141926"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="#0E1320"/>
            <Setter Property="Foreground" Value="#C9D3E8"/>
            <Setter Property="FontFamily" Value="Consolas, 'Courier New'"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#42506A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <Border x:Name="TrackSurface" Background="#101725" CornerRadius="5" Opacity="0.72"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="{TemplateBinding Foreground}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Height" Value="10"/>
                                <Setter TargetName="Root" Property="Margin" Value="0"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="10"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#5F7194"/>
                                <Setter TargetName="TrackSurface" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Margin="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" Margin="4,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#2B3550"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#31405F"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A2031"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#3A435B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="34"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="10,0,4,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="⌄" Foreground="{StaticResource TextMuted}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="Background" Value="#20283D"/>
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#58729F"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chrome" Property="Background" Value="#20283D"/>
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,38,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260" Margin="0,6,0,0">
                                    <Border Background="#151B2A" BorderBrush="#36435B" BorderThickness="1" CornerRadius="10"/>
                                    <ScrollViewer Margin="4" CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#687184"/>
                                <Setter TargetName="ToggleButton" Property="Background" Value="#1A2030"/>
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#2A3143"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#252D42"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#3A435B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#303A55"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#58729F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1D2434"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#687184"/>
                                <Setter TargetName="Chrome" Property="Background" Value="#1A2030"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2A3143"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,16,9"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,18,9"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#1A2030"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="flowBandOneTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="-320" To="1320"
                                     Duration="0:0:18"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="flowBandOneTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="-36" To="82"
                                     Duration="0:0:18"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="flowBandTwoTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="1220" To="-620"
                                     Duration="0:0:24"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="flowBandTwoTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="48" To="-72"
                                     Duration="0:0:24"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="gridFlowTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="0" To="44"
                                     Duration="0:0:12"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="gridFlowTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="44"
                                     Duration="0:0:18"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="scanLineTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="-180" To="880"
                                     Duration="0:0:11"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="scanColumnTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="-180" To="1280"
                                     Duration="0:0:15"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="dataStreamOpacity"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.15" To="0.34"
                                     Duration="0:0:5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="shellBackgroundStart" Color="#0B0F18" Offset="0"/>
                <GradientStop x:Name="shellBackgroundMid" Color="#111827" Offset="0.5"/>
                <GradientStop x:Name="shellBackgroundEnd" Color="#090D15" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="96"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.ColumnSpan="2" IsHitTestVisible="False" ClipToBounds="True">
            <Rectangle Opacity="0.26" Width="1120" Height="220" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-520,-42,0,0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#145DE2FF" Offset="0.34"/>
                        <GradientStop Color="#626FE7FF" Offset="0.48"/>
                        <GradientStop Color="#5A5DE2FF" Offset="0.52"/>
                        <GradientStop Color="#126EA2FF" Offset="0.66"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <RotateTransform Angle="-16"/>
                        <TranslateTransform x:Name="flowBandOneTranslate"/>
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>

            <Rectangle Opacity="0.22" Width="900" Height="190" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,-56">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#125C7CFF" Offset="0.28"/>
                        <GradientStop Color="#4A5DE2FF" Offset="0.48"/>
                        <GradientStop Color="#5A5DE2FF" Offset="0.52"/>
                        <GradientStop Color="#145DE2FF" Offset="0.72"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <RotateTransform Angle="18"/>
                        <TranslateTransform x:Name="flowBandTwoTranslate"/>
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>

            <Rectangle x:Name="dataStreamOpacity" Opacity="0.18">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,44,44" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Geometry="M 0,0 L 44,0">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#225DE2FF" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                </GeometryDrawing>
                                <GeometryDrawing Geometry="M 0,0 L 0,44">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#184B5F7A" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                </GeometryDrawing>
                                <GeometryDrawing Geometry="M 0,44 L 44,0">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#0F5DE2FF" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <TranslateTransform x:Name="gridFlowTranslate"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <Grid Height="170" VerticalAlignment="Top" Opacity="0.24">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="scanLineTranslate"/>
                </Grid.RenderTransform>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#0F5DE2FF" Offset="0.36"/>
                            <GradientStop Color="#285DE2FF" Offset="0.5"/>
                            <GradientStop Color="#0C5DE2FF" Offset="0.68"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Height="1.4" VerticalAlignment="Center" Opacity="0.46" Fill="#7AE8FF"/>
                <Rectangle Height="18" VerticalAlignment="Center" Opacity="0.30">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#285DE2FF" Offset="0.16"/>
                            <GradientStop Color="#607AE8FF" Offset="0.52"/>
                            <GradientStop Color="#205DE2FF" Offset="0.84"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>

            <Grid Width="170" HorizontalAlignment="Left" Opacity="0.22">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="scanColumnTranslate"/>
                </Grid.RenderTransform>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#0C5DE2FF" Offset="0.34"/>
                            <GradientStop Color="#245DE2FF" Offset="0.5"/>
                            <GradientStop Color="#0E5DE2FF" Offset="0.66"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Width="1.4" HorizontalAlignment="Center" Opacity="0.42" Fill="#7AE8FF"/>
                <Rectangle Width="18" HorizontalAlignment="Center" Opacity="0.28">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#225DE2FF" Offset="0.18"/>
                            <GradientStop Color="#587AE8FF" Offset="0.5"/>
                            <GradientStop Color="#1C5DE2FF" Offset="0.82"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
        </Grid>

        <Border Grid.Column="0" Background="#121827" BorderBrush="#263046" BorderThickness="0,0,1,0">
            <Grid Margin="0,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Width="34" Height="34" CornerRadius="10" Background="#1F2B46" HorizontalAlignment="Center">
                    <TextBlock Text="T" Foreground="{StaticResource AccentBlue}" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="10,0">
                    <Border x:Name="projectStepCard" CornerRadius="14" Background="#F5F7FB" Padding="10,9" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="projectStepNumber" Text="01" Foreground="#111827" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="projectStepLabel" Text="项目" Foreground="#111827" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="versionStepCard" CornerRadius="14" Background="#1D2435" Padding="10,9" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="versionStepNumber" Text="02" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="versionStepLabel" Text="版本" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="optionsStepCard" CornerRadius="14" Background="#1D2435" Padding="10,9" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="optionsStepNumber" Text="03" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="optionsStepLabel" Text="选项" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="installStepCard" CornerRadius="14" Background="#1D2435" Padding="10,9">
                        <StackPanel>
                            <TextBlock x:Name="installStepNumber" Text="04" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="installStepLabel" Text="安装" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border x:Name="railStatusBadge" Grid.Row="2" Width="34" Height="34" CornerRadius="17" Background="#1D2435" HorizontalAlignment="Center">
                    <TextBlock x:Name="railStatusText" Text="…" Foreground="#AEB7CB" FontSize="15" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#263046" BorderThickness="0,0,0,1" Background="#121827CC">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="TAPython Installer" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
                    <TextBlock Grid.Column="1" Text="UE Plugin Setup" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="26,0,0,0" FontSize="12"/>
                    <Border Grid.Column="3" Height="34" CornerRadius="17" Background="#1D2435" VerticalAlignment="Center" Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="●" Foreground="{StaticResource AccentCyan}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,1"/>
                            <TextBlock Grid.Column="1" x:Name="topStatusLabel" Text="等待选择项目" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="4" Width="36" Height="36" CornerRadius="18" Background="#20283A" Margin="12,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="AI" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="5" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="─" Width="38" Height="32" Padding="0" Margin="0,0,4,0" Click="MinimizeWindow_Click"/>
                        <Button Content="□" Width="38" Height="32" Padding="0" Margin="0,0,4,0" Click="ToggleMaximizeWindow_Click"/>
                        <Button Content="×" Width="38" Height="32" Padding="0" Background="#35243A" BorderBrush="#5A3343" Click="CloseWindow_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,14,24,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource DashboardCard}" Background="{StaticResource HeroBrush}" Margin="0,0,0,8" Height="66">
                    <Grid Margin="18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="安装诊断" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="Light" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                                <Border CornerRadius="12" Background="#2B3551" Padding="10,5" Margin="0,0,8,0">
                                    <TextBlock x:Name="projectHeroChip" Text="PROJECT PENDING" Foreground="{StaticResource TextSecondary}" FontSize="10.5" FontWeight="SemiBold"/>
                                </Border>
                                <Border CornerRadius="12" Background="#35283F" Padding="10,5">
                                    <TextBlock x:Name="sourceHeroChip" Text="SOURCE PENDING" Foreground="{StaticResource AccentOrange}" FontSize="10.5" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Width="420" VerticalAlignment="Center" Background="#182136" BorderBrush="#33405C" BorderThickness="1" CornerRadius="10" Padding="14,9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="当前状态" Style="{StaticResource MetricCaption}"/>
                                <TextBlock Grid.Column="1" x:Name="heroCurrentStatusText" Text="等待选择项目" Style="{StaticResource MetricValue}" Margin="0,0,14,0"/>
                                <TextBlock Grid.Column="2" Text="下一步" Style="{StaticResource MetricCaption}"/>
                                <TextBlock Grid.Column="3" x:Name="heroNextActionText" Text="选择 .uproject 文件" Style="{StaticResource MetricValue}"/>
                                <TextBlock x:Name="heroTargetText" Text="项目 Plugins" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource DashboardCard}" Margin="0,0,0,8" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                <TextBlock Text="项目与引擎" Style="{StaticResource SectionTitle}" Margin="0"/>
                                <TextBlock Text="Project &amp; Engine" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="项目 .uproject" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="projectPathBox" Margin="0,0,0,5"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="浏览..." Width="82" Padding="10,7" Margin="8,0,0,5" Click="BrowseProject_Click"/>

                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="projectStatusLabel" Text="请选择 .uproject 文件" Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="installedStatusLabel" Text="当前安装状态：未知" Style="{StaticResource StatusLabel}" Margin="0,3,0,8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="引擎目录" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="enginePathBox" Margin="0,0,0,5"/>
                            <Button Grid.Row="4" Grid.Column="2" Content="浏览..." Width="82" Padding="10,7" Margin="8,0,0,5" Click="BrowseEngine_Click"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="已发现引擎" Style="{StaticResource FieldLabel}"/>
                            <StackPanel Grid.Row="5" Grid.Column="1">
                                <ComboBox x:Name="engineCombo" SelectionChanged="EngineCombo_SelectionChanged"/>
                                <TextBlock x:Name="engineStatusLabel"
                                           Text="会扫描 Epic Launcher 引擎、注册表 Source Builds，以及 D:\AntLibs\WS"
                                           Style="{StaticResource StatusLabel}"/>
                            </StackPanel>
                            <Button Grid.Row="5" Grid.Column="2" Content="扫描" Width="82" Padding="10,7" Margin="8,0,0,0" VerticalAlignment="Top" Click="ScanEngines_Click"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource DashboardCard}" CornerRadius="12" Margin="0,0,0,0" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                <TextBlock Text="安装配置" Style="{StaticResource SectionTitle}" Margin="0"/>
                                <TextBlock Text="Release source and setup options" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="远程版本" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="releaseCombo" Margin="0,0,0,6"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="刷新列表" Width="82" Padding="10,7" Margin="8,0,0,6" Click="RefreshReleases_Click"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="离线安装" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="localZipLabel"
                                       Text="未选择本地 ZIP；选择后将优先使用本地 ZIP"
                                       Style="{StaticResource StatusLabel}" VerticalAlignment="Center"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="选择 ZIP" Width="82" Padding="10,7" Margin="8,0,0,0" Click="SelectLocalZip_Click"/>

                            <Border Grid.Row="3" Grid.ColumnSpan="3" Background="#171E2E" BorderBrush="#313B54" BorderThickness="1" CornerRadius="9" Margin="0,10,0,0" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.02*"/>
                                        <ColumnDefinition Width="1.18*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="安装位置" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,6"/>
                                        <WrapPanel>
                                            <RadioButton x:Name="projectInstallRadio" Content="项目 Plugins/" IsChecked="True"/>
                                            <RadioButton x:Name="engineInstallRadio" Content="引擎 Marketplace/"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                        <TextBlock Text="自动配置" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,6"/>
                                        <WrapPanel>
                                            <CheckBox x:Name="autoEnablePythonBox" Content="PythonScriptPlugin" IsChecked="True"/>
                                            <CheckBox x:Name="autoEnableTapythonBox" Content="TAPython 插件" IsChecked="True"/>
                                            <CheckBox x:Name="configurePythonPathBox" Content="Python 附加路径" IsChecked="True"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="安全与修复" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,6"/>
                                        <WrapPanel>
                                            <CheckBox x:Name="fixBuildIdBox" Content="修复 BuildId" IsChecked="True"/>
                                            <CheckBox x:Name="backupBox" Content="覆盖前备份" IsChecked="True"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="136"/>
                        <RowDefinition Height="190"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DashboardCard}" Margin="0,0,10,12" Padding="16">
                        <Grid>
                            <TextBlock Text="安装进度" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="installProgressText" Text="0%" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Light" HorizontalAlignment="Right" Margin="0,18,0,0"/>
                            <TextBlock x:Name="installStateText" Text="等待安装" Foreground="{StaticResource AccentCyan}" FontSize="12" VerticalAlignment="Bottom"/>
                            <Ellipse Width="78" Height="78" Fill="#2B6FFF" Opacity="0.12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="46" Height="46" Fill="#6EA2FF" Opacity="0.36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DashboardCard}" Margin="0,0,0,12" Padding="14">
                        <StackPanel>
                            <TextBlock Text="准备状态" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Project" Style="{StaticResource MetricCaption}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="projectCheckText" Text="未选择" Style="{StaticResource MetricValue}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Engine" Style="{StaticResource MetricCaption}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="engineCheckText" Text="未选择" Style="{StaticResource MetricValue}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Source" Style="{StaticResource MetricCaption}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="sourceCheckText" Text="未选择" Style="{StaticResource MetricValue}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Target" Style="{StaticResource MetricCaption}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="targetCheckText" Text="项目 Plugins" Style="{StaticResource MetricValue}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource DashboardCard}" Padding="0" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#333B52" BorderThickness="0,0,0,1" Padding="16,0">
                                <Grid>
                                    <TextBlock Text="安装日志" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text="Recent events" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <TextBox Grid.Row="1" x:Name="logBox" Style="{StaticResource LogBoxStyle}" Margin="10"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource DashboardCard}" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="操作流程" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                            <Grid Grid.Row="1" Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Row="0" Width="18" Height="18" CornerRadius="9" Background="#2B3551" HorizontalAlignment="Left">
                                    <TextBlock Text="1" Foreground="{StaticResource TextPrimary}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="选择 .uproject 并确认引擎" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,1,0,10"/>
                                <Border Grid.Row="1" Width="18" Height="18" CornerRadius="9" Background="#2B3551" HorizontalAlignment="Left">
                                    <TextBlock Text="2" Foreground="{StaticResource TextPrimary}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="选择 Release 或本地 ZIP，确认安装配置" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,1,0,10"/>
                                <Border Grid.Row="2" Width="18" Height="18" CornerRadius="9" Background="#2B3551" HorizontalAlignment="Left">
                                    <TextBlock Text="3" Foreground="{StaticResource TextPrimary}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="执行安装并在最近事件中查看关键结果" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,1,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ProgressBar Grid.Row="0" x:Name="progressBar" Height="7" Minimum="0" Maximum="100"/>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="pipelineStatusText" Text="请选择 .uproject 文件开始" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="openProjectButton" Content="打开项目" Width="118" Height="42" Padding="12,0"
                                IsEnabled="False" Margin="0,0,10,0" Click="OpenProject_Click"/>
                        <Button Grid.Column="2" x:Name="uninstallButton" Content="卸载 TAPython" Width="132" Height="42" Padding="12,0"
                            IsEnabled="False" Margin="0,0,10,0" Click="Uninstall_Click"/>
                        <Button Grid.Column="3" x:Name="installButton" Style="{StaticResource PrimaryButton}" Content="一键安装 TAPython"
                                Width="196" Height="42" Padding="16,0" FontSize="14" Click="Install_Click"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
