<Window x:Class="TAPythonInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:TAPythonInstaller"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="TAPython 快速安装器"
        Icon="Assets/AppIcon.ico"
        Width="1350" Height="790"
        MinWidth="920" MinHeight="660"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0B0F18">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="58"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="shellBackgroundStart" Color="#0B0F18" Offset="0"/>
                <GradientStop x:Name="shellBackgroundMid" Color="#111827" Offset="0.5"/>
                <GradientStop x:Name="shellBackgroundEnd" Color="#090D15" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="navigationColumn" Width="216"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:AnimatedBackground x:Name="animatedBackground" Grid.ColumnSpan="2"/>

        <Border Grid.Column="0" x:Name="navigationRail" Background="#121827" BorderBrush="#263046" BorderThickness="0,0,1,0">
            <Grid Margin="12,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid x:Name="navHeaderGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="navLogoMark" Width="36" Height="36" CornerRadius="10" Background="#1F2B46" HorizontalAlignment="Left">
                        <TextBlock Text="T" Foreground="{StaticResource AccentBlue}" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel x:Name="navBrandText" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="TAPython" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="工作台" Foreground="{StaticResource TextMuted}" FontSize="10.5"/>
                    </StackPanel>
                    <Button Grid.Column="2" x:Name="navCollapseButton" Content="‹" Width="30" Height="30" Padding="0" Click="ToggleNavigation_Click" ToolTip="收起导航" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>

                <ListBox Grid.Row="1" x:Name="navList" Margin="0,22,0,12"
                         Style="{StaticResource NavigationListBox}"
                         ItemContainerStyle="{StaticResource NavigationListBoxItem}"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                           FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" x:Name="NavItemText" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Title}" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextMuted}" FontSize="10.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding NavIsCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter TargetName="NavItemText" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2">
                    <Border x:Name="installerUpdatePanel" Background="#151B2A" BorderBrush="#2D3850" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,2,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <TextBlock Text="安装器" Foreground="{StaticResource TextPrimary}" FontSize="11.5" FontWeight="SemiBold"/>
                                <TextBlock x:Name="installerUpdateStatusText" Text="未检查" Foreground="{StaticResource TextMuted}" FontSize="10.5" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,8,0,9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="当前" Foreground="{StaticResource TextMuted}" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" x:Name="installerCurrentVersionText" Text="v--" Foreground="{StaticResource TextSecondary}" FontSize="10.5" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="1" Text="最新" Foreground="{StaticResource TextMuted}" FontSize="10.5" Margin="0,3,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="installerLatestVersionText" Text="未检查" Foreground="{StaticResource TextSecondary}" FontSize="10.5" HorizontalAlignment="Right" Margin="0,3,0,0"/>
                            </Grid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="installerCheckButton" Content="检查" Height="30" Padding="10,0" Margin="0,0,5,0" Click="InstallerCheckButton_Click"/>
                                <Button Grid.Column="1" x:Name="installerUpdateButton" Content="更新" Height="30" Padding="10,0" Margin="5,0,0,0" Click="InstallerUpdateButton_Click"/>
                            </Grid>
                            <Button Grid.Row="3" Content="更新日志" Height="28" Margin="0,8,0,0" Padding="10,0" Click="ShowUpdateLog_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#263046" BorderThickness="0,0,0,1" Background="#121827CC">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="TAPython Installer" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
                    <TextBlock Grid.Column="1" Text="UE 插件配置" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="26,0,0,0" FontSize="12"/>
                    <Border Grid.Column="3" Height="34" CornerRadius="17" Background="#1D2435" VerticalAlignment="Center" Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="topStatusDot" Text="●" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,1"/>
                            <TextBlock Grid.Column="1" x:Name="topStatusLabel" Text="等待选择项目" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="4" Width="36" Height="36" CornerRadius="18" Background="#20283A" Margin="12,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="AI" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="5" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowControlButton}" Content="─" Width="38" Height="32" Padding="0" Margin="0,0,4,0" Click="MinimizeWindow_Click"/>
                        <Button Style="{StaticResource WindowControlButton}" Content="□" Width="38" Height="32" Padding="0" Margin="0,0,4,0" Click="ToggleMaximizeWindow_Click"/>
                        <Button Style="{StaticResource CloseWindowButton}" Content="×" Width="38" Height="32" Padding="0" Click="CloseWindow_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="installPageGrid" Grid.Row="1" Margin="24,14,24,14" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource DashboardCard}" Background="{StaticResource HeroBrush}" Margin="0,0,0,8" Height="66">
                    <Grid Margin="18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="安装诊断" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="Light" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                                <Border CornerRadius="12" Background="#2B3551" Padding="10,5" Margin="0,0,8,0">
                                    <TextBlock x:Name="projectHeroChip" Text="项目待选择" Foreground="{StaticResource TextSecondary}" FontSize="10.5" FontWeight="SemiBold"/>
                                </Border>
                                <Border CornerRadius="12" Background="#35283F" Padding="10,5">
                                    <TextBlock x:Name="sourceHeroChip" Text="安装源待选择" Foreground="{StaticResource AccentOrange}" FontSize="10.5" FontWeight="SemiBold"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                                    <Border x:Name="projectStepCard" CornerRadius="10" Background="#F5F7FB" Padding="8,5" Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="projectStepNumber" Text="01" Foreground="#111827" FontSize="10.5" FontWeight="Bold"/>
                                            <TextBlock x:Name="projectStepLabel" Text="项目" Foreground="#111827" FontSize="10.5" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="versionStepCard" CornerRadius="10" Background="#1D2435" Padding="8,5" Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="versionStepNumber" Text="02" Foreground="{StaticResource TextMuted}" FontSize="10.5" FontWeight="Bold"/>
                                            <TextBlock x:Name="versionStepLabel" Text="版本" Foreground="{StaticResource TextMuted}" FontSize="10.5" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="optionsStepCard" CornerRadius="10" Background="#1D2435" Padding="8,5" Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="optionsStepNumber" Text="03" Foreground="{StaticResource TextMuted}" FontSize="10.5" FontWeight="Bold"/>
                                            <TextBlock x:Name="optionsStepLabel" Text="选项" Foreground="{StaticResource TextMuted}" FontSize="10.5" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="installStepCard" CornerRadius="10" Background="#1D2435" Padding="8,5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="installStepNumber" Text="04" Foreground="{StaticResource TextMuted}" FontSize="10.5" FontWeight="Bold"/>
                                            <TextBlock x:Name="installStepLabel" Text="安装" Foreground="{StaticResource TextMuted}" FontSize="10.5" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Width="316" VerticalAlignment="Center" Background="#182136" BorderBrush="#33405C" BorderThickness="1" CornerRadius="10" Padding="10,9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="58"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="当前状态" Style="{StaticResource MetricCaption}"/>
                                <TextBlock Grid.Column="1" x:Name="heroCurrentStatusText" Text="等待选择项目" Style="{StaticResource MetricValue}" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="2" Text="下一步" Style="{StaticResource MetricCaption}"/>
                                <TextBlock Grid.Column="3" x:Name="heroNextActionText" Text="选择 .uproject 文件" Style="{StaticResource MetricValue}"/>
                                <TextBlock x:Name="heroTargetText" Text="项目 Plugins" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource DashboardCard}" Margin="0,0,0,8" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                <TextBlock Text="项目与引擎" Style="{StaticResource SectionTitle}" Margin="0"/>
                                <TextBlock Text="项目路径与引擎识别" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="项目 .uproject" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="projectPathBox" Margin="0,0,0,5"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="浏览..." Width="82" Padding="10,7" Margin="8,0,0,5" Click="BrowseProject_Click"/>

                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="projectStatusLabel" Text="请选择 .uproject 文件" Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="installedStatusLabel" Text="当前安装状态：未知" Style="{StaticResource StatusLabel}" Margin="0,3,0,8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="引擎目录" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="enginePathBox" Margin="0,0,0,5"/>
                            <Button Grid.Row="4" Grid.Column="2" Content="浏览..." Width="82" Padding="10,7" Margin="8,0,0,5" Click="BrowseEngine_Click"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="已发现引擎" Style="{StaticResource FieldLabel}"/>
                            <StackPanel Grid.Row="5" Grid.Column="1">
                                <ComboBox x:Name="engineCombo" SelectionChanged="EngineCombo_SelectionChanged"/>
                                <TextBlock x:Name="engineStatusLabel"
                                           Text="会扫描 Epic Launcher 引擎、注册表 Source Builds，以及 D:\AntLibs\WS"
                                           Style="{StaticResource StatusLabel}"/>
                            </StackPanel>
                            <Button Grid.Row="5" Grid.Column="2" Content="扫描" Width="82" Padding="10,7" Margin="8,0,0,0" VerticalAlignment="Top" Click="ScanEngines_Click"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource DashboardCard}" CornerRadius="12" Margin="0,0,0,0" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                <TextBlock Text="安装配置" Style="{StaticResource SectionTitle}" Margin="0"/>
                                <TextBlock Text="版本来源与安装选项" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="远程版本" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="releaseCombo" Margin="0,0,0,6"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="刷新列表" Width="82" Padding="10,7" Margin="8,0,0,6" Click="RefreshReleases_Click"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="离线安装" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="localZipLabel"
                                       Text="未选择本地 ZIP；选择后将优先使用本地 ZIP"
                                       Style="{StaticResource StatusLabel}" VerticalAlignment="Center"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="选择 ZIP" Width="82" Padding="10,7" Margin="8,0,0,0" Click="SelectLocalZip_Click"/>

                            <Border Grid.Row="3" Grid.ColumnSpan="3" Background="#171E2E" BorderBrush="#313B54" BorderThickness="1" CornerRadius="9" Margin="0,10,0,0" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.95*"/>
                                        <ColumnDefinition Width="1.08*"/>
                                        <ColumnDefinition Width="0.78*"/>
                                        <ColumnDefinition Width="1.12*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <TextBlock Text="安装位置" Foreground="{StaticResource TextMuted}" FontSize="11" Height="22" VerticalAlignment="Center"/>
                                        <WrapPanel Margin="0,2,0,0">
                                            <RadioButton x:Name="projectInstallRadio" Content="项目 Plugins/" IsChecked="True"/>
                                            <RadioButton x:Name="engineInstallRadio" Content="引擎 Marketplace/"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                        <TextBlock Text="自动配置" Foreground="{StaticResource TextMuted}" FontSize="11" Height="22" VerticalAlignment="Center"/>
                                        <WrapPanel Margin="0,2,0,0">
                                            <CheckBox x:Name="autoEnablePythonBox" Content="PythonScriptPlugin" IsChecked="True"/>
                                            <CheckBox x:Name="autoEnableTapythonBox" Content="TAPython 插件" IsChecked="True"/>
                                            <CheckBox x:Name="configurePythonPathBox" Content="Python 附加路径" IsChecked="True"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,14,0">
                                        <TextBlock Text="安全与修复" Foreground="{StaticResource TextMuted}" FontSize="11" Height="22" VerticalAlignment="Center"/>
                                        <WrapPanel Margin="0,2,0,0">
                                            <CheckBox x:Name="fixBuildIdBox" Content="修复 BuildId" IsChecked="True"/>
                                            <CheckBox x:Name="backupBox" Content="覆盖前备份" IsChecked="True"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <Grid Grid.Column="3">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Agent Skills" Foreground="{StaticResource TextMuted}" FontSize="11" Height="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Button Grid.Row="0" Grid.Column="1" Content="更新" Width="62" Height="22" Padding="8,0" FontSize="11" VerticalAlignment="Center" Click="UpdateSelectedAgentSkills_Click" ToolTip="删除并重新部署已勾选的内置 Agent Skills"/>
                                        <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,2,0,0">
                                            <CheckBox x:Name="installTapythonGeneratorSkillBox" Content="tapython-generator" IsChecked="True"/>
                                            <CheckBox x:Name="installTapythonHubPublisherSkillBox" Content="tapython-hub-publisher" IsChecked="True"/>
                                            <CheckBox x:Name="installUeApiNavigatorSkillBox" Content="ue-api-navigator" IsChecked="True"/>
                                        </WrapPanel>
                                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="部署到当前用户 .copilot/skills" Foreground="{StaticResource TextMuted}" FontSize="10.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="136"/>
                        <RowDefinition Height="190"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DashboardCard}" Margin="0,0,10,12" Padding="16">
                        <Grid>
                            <TextBlock Text="安装进度" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="installProgressText" Text="0%" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Light" HorizontalAlignment="Right" Margin="0,18,0,0"/>
                            <TextBlock x:Name="installStateText" Text="等待安装" Foreground="{StaticResource AccentCyan}" FontSize="12" VerticalAlignment="Bottom"/>
                            <Ellipse Width="78" Height="78" Fill="#2B6FFF" Opacity="0.12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="46" Height="46" Fill="#6EA2FF" Opacity="0.36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DashboardCard}" Margin="0,0,0,12" Padding="14">
                        <StackPanel>
                            <TextBlock Text="准备状态" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Project" Style="{StaticResource MetricCaption}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="projectCheckText" Text="未选择" Style="{StaticResource MetricValue}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Engine" Style="{StaticResource MetricCaption}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="engineCheckText" Text="未选择" Style="{StaticResource MetricValue}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Source" Style="{StaticResource MetricCaption}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="sourceCheckText" Text="未选择" Style="{StaticResource MetricValue}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Target" Style="{StaticResource MetricCaption}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="targetCheckText" Text="项目 Plugins" Style="{StaticResource MetricValue}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource DashboardCard}" Padding="0" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#333B52" BorderThickness="0,0,0,1" Padding="16,0">
                                <Grid>
                                    <TextBlock Text="安装日志" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text="最近事件" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <TextBox Grid.Row="1" x:Name="logBox" Style="{StaticResource LogBoxStyle}" Margin="10"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource DashboardCard}" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="操作流程" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                            <Grid Grid.Row="1" Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Row="0" Width="18" Height="18" CornerRadius="9" Background="#2B3551" HorizontalAlignment="Left">
                                    <TextBlock Text="1" Foreground="{StaticResource TextPrimary}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="选择 .uproject 并确认引擎" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,1,0,10"/>
                                <Border Grid.Row="1" Width="18" Height="18" CornerRadius="9" Background="#2B3551" HorizontalAlignment="Left">
                                    <TextBlock Text="2" Foreground="{StaticResource TextPrimary}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="选择 Release 或本地 ZIP，确认安装配置" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,1,0,10"/>
                                <Border Grid.Row="2" Width="18" Height="18" CornerRadius="9" Background="#2B3551" HorizontalAlignment="Left">
                                    <TextBlock Text="3" Foreground="{StaticResource TextPrimary}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="执行安装并在最近事件中查看关键结果" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,1,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ProgressBar Grid.Row="0" x:Name="progressBar" Height="7" Minimum="0" Maximum="100"/>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="pipelineStatusText" Text="请选择 .uproject 文件开始" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" x:Name="openProjectButton" Content="打开项目" Width="108" Height="42" Padding="10,0"
                                IsEnabled="False" Margin="0,0,10,0" Click="OpenProject_Click"/>
                        <Button Grid.Column="2" x:Name="uninstallButton" Content="卸载 TAPython" Width="122" Height="42" Padding="10,0"
                            IsEnabled="False" Margin="0,0,10,0" Click="Uninstall_Click"/>
                        <Button Grid.Column="3" x:Name="installButton" Style="{StaticResource PrimaryButton}" Content="一键安装 TAPython"
                            Width="180" Height="42" Padding="14,0" FontSize="14" Click="Install_Click"/>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="toolsPageGrid" Grid.Row="1" Margin="24,14,24,14" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource DashboardCard}" Background="{StaticResource HeroBrush}" Margin="0,0,0,10" Height="72">
                    <Grid Margin="18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TAPython 脚本工具" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="Light"/>
                            <TextBlock Text="项目工具与 TAPython Tool Hub 资源" Foreground="{StaticResource TextMuted}" FontSize="11.5" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#182136" BorderBrush="#33405C" BorderThickness="1" CornerRadius="10" Padding="14,9" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="当前项目" Style="{StaticResource MetricCaption}" Margin="0,0,10,0"/>
                                <TextBlock x:Name="toolsProjectSummaryText" Text="未选择" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource DashboardCard}" Padding="8" Margin="0,0,0,10">
                    <Grid x:Name="toolTabsHost" MouseLeftButtonDown="ToolTabsHost_MouseLeftButtonDown" MouseLeftButtonUp="ToolTabsHost_MouseLeftButtonUp">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="projectToolsTabButton" Content="当前项目扫描到的工具" Height="38" Margin="0,0,6,0" Click="ProjectToolsTab_Click"/>
                        <Button Grid.Column="1" x:Name="hubToolsTabButton" Content="TAPython 工具分享网站" Height="38" Margin="6,0,0,0" Click="HubToolsTab_Click"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Border x:Name="projectToolsPanel" Style="{StaticResource DashboardCard}" Padding="16" PreviewMouseDown="ToolPanel_PreviewMouseDown" AllowDrop="True" DragOver="ProjectToolsPanel_DragOver" DragLeave="ProjectToolsPanel_DragLeave" Drop="ProjectToolsPanel_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="当前项目工具" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="导入" Width="72" Height="32" Margin="0,0,8,0" Click="ImportProjectTool_Click"/>
                                    <Button Content="导出" Width="72" Height="32" Margin="0,0,8,0" Click="ExportProjectTool_Click"/>
                                    <Button x:Name="uploadProjectToolButton" Content="AI 发布" Width="86" Height="32" Margin="0,0,8,0" Click="UploadProjectTool_Click" ToolTip="为选中的项目工具生成 Copilot 发布上下文，并打开 VS Code 调用 tapython-hub-publisher"/>
                                    <Button Content="发布结果" Width="86" Height="32" Margin="0,0,8,0" Click="ViewAiPublishResult_Click" ToolTip="读取选中工具最近一次 AI 发布输出报告"/>
                                    <Button Content="提交Hub" Width="86" Height="32" Margin="0,0,8,0" Click="SubmitAiPublishToToolHub_Click" ToolTip="将最新 ready 状态的 AI 发布包提交到 ToolHub 审核队列"/>
                                    <Button Content="删除" Width="72" Height="32" Margin="0,0,8,0" Click="DeleteProjectTool_Click"/>
                                    <Button Content="重新扫描" Width="92" Height="32" Click="RefreshProjectTools_Click"/>
                                </StackPanel>
                            </Grid>
                            <ListBox Grid.Row="1" x:Name="projectToolsList" Style="{StaticResource NavigationListBox}" ItemContainerStyle="{StaticResource ToolListBoxItem}" PreviewMouseDown="ToolList_PreviewMouseDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="8" Background="#1F2B46" HorizontalAlignment="Left">
                                                <TextBlock Text="TA" Foreground="{StaticResource AccentCyan}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <Border Background="#1F2B46" BorderBrush="#334563" BorderThickness="1" CornerRadius="7" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding VersionText}" Foreground="{StaticResource TextMuted}" FontSize="10.5" FontWeight="SemiBold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Kind}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="projectToolsEmptyText" Grid.Row="1" Text="选择项目后可扫描 TA/TAPython/Python 中已有工具。" Style="{StaticResource EmptyStateText}"/>
                            <Border x:Name="projectToolDropOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#D9131A2A" BorderBrush="{StaticResource AccentCyan}" BorderThickness="2" CornerRadius="8" IsHitTestVisible="False">
                                <Grid>
                                    <Border Background="#E5101728" BorderBrush="#334563" BorderThickness="1" CornerRadius="8" Padding="30,18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="拖拽导入工具" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="hubToolsPanel" Style="{StaticResource DashboardCard}" Padding="16" Visibility="Collapsed" PreviewMouseDown="ToolPanel_PreviewMouseDown">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.45*"/>
                                    <ColumnDefinition Width="0.82*"/>
                                    <ColumnDefinition Width="0.72*"/>
                                    <ColumnDefinition Width="0.82*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Height="34" Margin="0,0,8,0">
                                    <TextBox x:Name="hubSearchBox" Padding="58,0,36,0" VerticalContentAlignment="Center" ToolTip="按工具名称、说明、作者或标签搜索"/>
                                    <TextBlock Text="搜索" Foreground="{StaticResource AccentCyan}" FontSize="11" FontWeight="SemiBold" Margin="13,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    <TextBlock x:Name="hubSearchPlaceholderText" Text="名称 / 作者 / 标签" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="58,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    <Button x:Name="hubSearchClearButton" Style="{StaticResource SearchClearButton}" Content="×" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0" ToolTip="清空搜索" Click="ClearHubSearch_Click" Visibility="Collapsed"/>
                                </Grid>
                                <ComboBox Grid.Column="1" x:Name="hubCategoryFilter" Height="34" Margin="0,0,8,0"/>
                                <ComboBox Grid.Column="2" x:Name="hubRiskFilter" Height="34" Margin="0,0,8,0"/>
                                <ComboBox Grid.Column="3" x:Name="hubStatusFilter" Height="34" Margin="0,0,8,0"/>
                                <ToggleButton Grid.Column="4" x:Name="hubCompatibleOnlyBox" Style="{StaticResource FilterToggleButton}" Content="仅兼容 UE" Width="118" Height="34" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="只显示兼容当前项目 UE 版本的工具"/>
                                <Button Grid.Column="5" x:Name="hubRefreshButton" Content="刷新" Width="76" Height="34" Click="RefreshHubTools_Click"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.25*" MinWidth="340"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="1*" MinWidth="300"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#171E2E" BorderBrush="#313B54" BorderThickness="1" CornerRadius="10" Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="2,0,2,10">
                                            <TextBlock Text="工具库" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="hubToolsCountText" Text="等待加载" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ListBox Grid.Row="1" x:Name="hubToolsList" Style="{StaticResource NavigationListBox}" ItemContainerStyle="{StaticResource ToolListBoxItem}" PreviewMouseDown="ToolList_PreviewMouseDown" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid MinHeight="128">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="44"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="32" Height="32" CornerRadius="9" Background="#1F2B46" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                            <TextBlock Text="Hub" Foreground="{StaticResource AccentCyan}" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}" FontSize="13.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="17" MaxHeight="52"/>
                                                            <WrapPanel Margin="0,10,0,0">
                                                                <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentCyan}" FontSize="11" Margin="0,0,12,0"/>
                                                                <TextBlock Text="{Binding CompatibilitySummary}" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,12,0"/>
                                                                <TextBlock Text="{Binding PackageSizeText}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Width="92" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding LatestVersion}" Foreground="{StaticResource TextPrimary}" FontSize="11.5" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                            <TextBlock x:Name="hubListStatusText" Text="{Binding HubListStatusText}" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Right" Margin="0,7,0,0"/>
                                                            <Border x:Name="hubListInstalledBadge" Background="#14312B" BorderBrush="#2E8F72" BorderThickness="1" CornerRadius="8" Padding="7,2" HorizontalAlignment="Right" Margin="0,7,0,0" Visibility="Collapsed">
                                                                <TextBlock Text="已安装" Foreground="#86EFAC" FontSize="10.5" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding RiskText}" Foreground="{StaticResource TextMuted}" FontSize="11" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                            <Setter TargetName="hubListStatusText" Property="Visibility" Value="Collapsed"/>
                                                            <Setter TargetName="hubListInstalledBadge" Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <TextBlock x:Name="hubToolsEmptyText" Grid.Row="1" Text="点击刷新加载公司内网 TAPython Tool Hub 工具。" Style="{StaticResource EmptyStateText}"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" x:Name="hubDetailPanel" Background="#171E2E" BorderBrush="#313B54" BorderThickness="1" CornerRadius="10" Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="hubDetailTitleText" Text="选择一个工具" Foreground="{StaticResource TextPrimary}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock x:Name="hubDetailMetaText" Text="工具详情、风险与安装预览会显示在这里" Foreground="{StaticResource TextMuted}" FontSize="11.5" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" x:Name="hubDetailStatusBadge" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" CornerRadius="8" Padding="8,3" VerticalAlignment="Top" Margin="14,0,0,0">
                                                <TextBlock x:Name="hubDetailStatusText" Text="未选择" Foreground="{StaticResource AccentCyan}" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock x:Name="hubDetailDescriptionText" Text="从左侧工具库选择工具，或点击刷新从 Tool Hub API 获取最新列表。" Foreground="{StaticResource TextSecondary}" FontSize="12.5" LineHeight="18" TextWrapping="Wrap"/>

                                                <Grid Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                        <TextBlock Text="兼容版本" Foreground="{StaticResource TextMuted}" FontSize="10.5"/>
                                                        <TextBlock x:Name="hubDetailCompatibilityText" Text="-" Foreground="{StaticResource TextPrimary}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="包与校验" Foreground="{StaticResource TextMuted}" FontSize="10.5"/>
                                                        <TextBlock x:Name="hubDetailPackageText" Text="-" Foreground="{StaticResource TextPrimary}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Text="标签" Foreground="{StaticResource TextMuted}" FontSize="10.5" Margin="0,14,0,0"/>
                                                <TextBlock x:Name="hubDetailTagsText" Text="-" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>

                                                <Grid Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="安装预览与安装" Foreground="{StaticResource TextMuted}" FontSize="10.5" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" x:Name="hubPreviewStatusBadge" Background="#1A2031" BorderBrush="#3A435B" BorderThickness="1" CornerRadius="8" Padding="8,3" VerticalAlignment="Center">
                                                        <TextBlock x:Name="hubPreviewStatusText" Text="未预览" Foreground="{StaticResource TextMuted}" FontSize="10.5" FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                                <Border Background="#111827" BorderBrush="#2A354E" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,6,0,0">
                                                    <TextBox x:Name="hubInstallPreviewText" Style="{StaticResource PreviewTextBoxStyle}" Text="点击“安装预览”后，会读取 Tool Hub 安装计划模板并结合当前项目生成预览；确认无误后可安装到当前项目。"/>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Grid Grid.Row="2" Margin="0,12,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" x:Name="hubStatusText" Text="API: http://10.2.13.8:8787" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                            <WrapPanel Grid.Row="1" HorizontalAlignment="Right">
                                                <Button x:Name="openHubInstallFolderButton" Content="安装目录" Width="86" Height="34" Margin="0,0,8,8" Click="OpenHubInstallFolder_Click" IsEnabled="False" ToolTip="打开上一次 Tool Hub 安装目标目录"/>
                                                <Button x:Name="openHubBackupFolderButton" Content="备份目录" Width="86" Height="34" Margin="0,0,8,8" Click="OpenHubBackupFolder_Click" IsEnabled="False" ToolTip="打开上一次 Tool Hub 安装备份目录"/>
                                                <Button x:Name="hubUninstallButton" Content="卸载工具" Width="86" Height="34" Margin="0,0,8,8" Click="HubUninstallTool_Click" IsEnabled="False" ToolTip="备份并卸载当前已安装的 Tool Hub 工具"/>
                                                <Button x:Name="hubRepairInstallButton" Content="修复安装" Width="86" Height="34" Margin="0,0,8,8" Click="HubRepairInstall_Click" IsEnabled="False" ToolTip="检查已安装 Tool Hub 工具路径，并修复旧版双层目录布局"/>
                                                <Button x:Name="hubRedownloadPreviewButton" Content="重新下载" Width="86" Height="34" Margin="0,0,8,8" Click="HubRedownloadPreview_Click" ToolTip="清除当前工具缓存包后重新生成安装预览"/>
                                                <Button x:Name="hubPreviewButton" Content="安装预览" Width="92" Height="34" Margin="0,0,8,8" Click="HubPreviewInstall_Click"/>
                                                <Button x:Name="hubInstallButton" Content="安装到项目" Width="96" Height="34" Margin="0,0,8,8" Click="HubInstallToProject_Click" ToolTip="下载校验通过后，将工具安装到当前项目 TA/TAPython/Python 目录"/>
                                                <Button Content="打开网站" Width="86" Height="34" Margin="0,0,0,8" Click="OpenToolHubWebsite_Click"/>
                                            </WrapPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="placeholderPageGrid" Grid.Row="1" Margin="24,14,24,14" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Border Style="{StaticResource DashboardCard}" Background="{StaticResource HeroBrush}" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="placeholderTitleText" Text="预留入口" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Light"/>
                            <TextBlock x:Name="placeholderSubtitleText" Text="这个入口已预留，后续可接入新的 TAPython 工作流。" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,8,0,0"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#171E2E" BorderBrush="#313B54" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="46" Height="46" CornerRadius="14" Background="#1F2B46">
                                    <TextBlock Text="+" Foreground="{StaticResource AccentCyan}" FontSize="24" FontWeight="Light" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="功能页面占位" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="当前先用于验证导航过渡效果。后续入口接入时，可以复用同一套页面切换动画。" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="updateLogOverlay" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#B80B0F18" Panel.ZIndex="30" MouseDown="UpdateLogOverlay_MouseDown">
            <Border Width="620" MaxHeight="620" Style="{StaticResource DashboardCard}" Background="#1B2233" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="22,18,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="更新日志" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="Light"/>
                            <TextBlock Text="TAPythonInstaller 中文版本说明" Foreground="{StaticResource TextMuted}" FontSize="11.5" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource CloseWindowButton}" Content="×" Width="34" Height="34" Padding="0" FontSize="18" Click="CloseUpdateLog_Click"/>
                    </Grid>
                    <Border Grid.Row="1" Background="#141B2B" BorderBrush="#303B54" BorderThickness="1" CornerRadius="9" Padding="12,9" Margin="22,0,18,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="30" Height="30" CornerRadius="9" Background="#1F2B46" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="新" Foreground="{StaticResource AccentCyan}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="最新版本在顶部，历史记录按时间倒序排列" Foreground="{StaticResource TextPrimary}" FontSize="12.5" FontWeight="SemiBold"/>
                                <TextBlock Text="自更新后首次启动会自动显示；也可随时从左下角打开查看。" Foreground="{StaticResource TextMuted}" FontSize="11.5" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <local:UpdateLogContent Grid.Row="2"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

