<UserControl x:Class="TAPythonInstaller.AnimatedBackground"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False"
             ClipToBounds="True">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="flowBandOneTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="-320" To="1320"
                                     Duration="0:0:18"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="flowBandOneTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="-36" To="82"
                                     Duration="0:0:18"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="flowBandTwoTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="1220" To="-620"
                                     Duration="0:0:24"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="flowBandTwoTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="48" To="-72"
                                     Duration="0:0:24"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="gridFlowTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="0" To="44"
                                     Duration="0:0:12"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="gridFlowTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="44"
                                     Duration="0:0:18"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="scanLineTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="-180" To="880"
                                     Duration="0:0:11"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="scanColumnTranslate"
                                     Storyboard.TargetProperty="X"
                                     From="-180" To="1280"
                                     Duration="0:0:15"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="dataStreamOpacity"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.15" To="0.34"
                                     Duration="0:0:5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Rectangle Opacity="0.26" Width="1120" Height="220" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-520,-42,0,0">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#145DE2FF" Offset="0.34"/>
                    <GradientStop Color="#626FE7FF" Offset="0.48"/>
                    <GradientStop Color="#5A5DE2FF" Offset="0.52"/>
                    <GradientStop Color="#126EA2FF" Offset="0.66"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <RotateTransform Angle="-16"/>
                    <TranslateTransform x:Name="flowBandOneTranslate"/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>

        <Rectangle Opacity="0.22" Width="900" Height="190" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,-56">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#125C7CFF" Offset="0.28"/>
                    <GradientStop Color="#4A5DE2FF" Offset="0.48"/>
                    <GradientStop Color="#5A5DE2FF" Offset="0.52"/>
                    <GradientStop Color="#145DE2FF" Offset="0.72"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <RotateTransform Angle="18"/>
                    <TranslateTransform x:Name="flowBandTwoTranslate"/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>

        <Rectangle x:Name="dataStreamOpacity" Opacity="0.18">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,44,44" ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Geometry="M 0,0 L 44,0">
                                <GeometryDrawing.Pen>
                                    <Pen Brush="#225DE2FF" Thickness="1"/>
                                </GeometryDrawing.Pen>
                            </GeometryDrawing>
                            <GeometryDrawing Geometry="M 0,0 L 0,44">
                                <GeometryDrawing.Pen>
                                    <Pen Brush="#184B5F7A" Thickness="1"/>
                                </GeometryDrawing.Pen>
                            </GeometryDrawing>
                            <GeometryDrawing Geometry="M 0,44 L 44,0">
                                <GeometryDrawing.Pen>
                                    <Pen Brush="#0F5DE2FF" Thickness="1"/>
                                </GeometryDrawing.Pen>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
            <Rectangle.RenderTransform>
                <TranslateTransform x:Name="gridFlowTranslate"/>
            </Rectangle.RenderTransform>
        </Rectangle>

        <Grid Height="170" VerticalAlignment="Top" Opacity="0.24">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="scanLineTranslate"/>
            </Grid.RenderTransform>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#0F5DE2FF" Offset="0.36"/>
                        <GradientStop Color="#285DE2FF" Offset="0.5"/>
                        <GradientStop Color="#0C5DE2FF" Offset="0.68"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle Height="1.4" VerticalAlignment="Center" Opacity="0.46" Fill="#7AE8FF"/>
            <Rectangle Height="18" VerticalAlignment="Center" Opacity="0.30">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#285DE2FF" Offset="0.16"/>
                        <GradientStop Color="#607AE8FF" Offset="0.52"/>
                        <GradientStop Color="#205DE2FF" Offset="0.84"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <Grid Width="170" HorizontalAlignment="Left" Opacity="0.22">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="scanColumnTranslate"/>
            </Grid.RenderTransform>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#0C5DE2FF" Offset="0.34"/>
                        <GradientStop Color="#245DE2FF" Offset="0.5"/>
                        <GradientStop Color="#0E5DE2FF" Offset="0.66"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle Width="1.4" HorizontalAlignment="Center" Opacity="0.42" Fill="#7AE8FF"/>
            <Rectangle Width="18" HorizontalAlignment="Center" Opacity="0.28">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#225DE2FF" Offset="0.18"/>
                        <GradientStop Color="#587AE8FF" Offset="0.5"/>
                        <GradientStop Color="#1C5DE2FF" Offset="0.82"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>
    </Grid>
</UserControl>
