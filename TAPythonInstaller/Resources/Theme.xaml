<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:TAPythonInstaller">
    <DropShadowEffect x:Key="PanelShadow" BlurRadius="22" ShadowDepth="0" Color="#000000" Opacity="0.34"/>

    <!-- ============ 液态玻璃材质 Token（Liquid Glass） ============ -->
    <!-- 玻璃材质三档：越靠近交互与正文，alpha 越高以保证可读性 -->
    <LinearGradientBrush x:Key="GlassSurface" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#46FFFFFF" Offset="0"/>
        <GradientStop Color="#18FFFFFF" Offset="0.05"/>
        <GradientStop Color="#332E3C64" Offset="0.5"/>
        <GradientStop Color="#3D232C4A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GlassSurfaceStrong" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#CC1A2138" Offset="0"/>
        <GradientStop Color="#CC141A2C" Offset="1"/>
    </LinearGradientBrush>

    <!-- 镜面高光边：顶亮底隐 -->
    <LinearGradientBrush x:Key="GlassStroke" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#8CFFFFFF" Offset="0"/>
        <GradientStop Color="#22FFFFFF" Offset="0.5"/>
        <GradientStop Color="#40FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- 控件玻璃底（按钮/输入/下拉，比卡片略实以保证可读） -->
    <SolidColorBrush x:Key="GlassControlSurface" Color="#5C28304C"/>
    <SolidColorBrush x:Key="GlassControlHover" Color="#73313C60"/>
    <SolidColorBrush x:Key="GlassControlPressed" Color="#8C1E2742"/>

    <!-- 导航栏：暗透融合背景，无强反光 -->
    <LinearGradientBrush x:Key="GlassRailSurface" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#42182038" Offset="0"/>
        <GradientStop Color="#36101630" Offset="1"/>
    </LinearGradientBrush>

    <!-- 内层分区面板（卡片内的子容器） -->
    <SolidColorBrush x:Key="GlassInnerPanel" Color="#4A18223E"/>

    <!-- 顶部内高光（玻璃反光条） -->
    <LinearGradientBrush x:Key="GlassTopSheen" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3AFFFFFF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="0.45"/>
    </LinearGradientBrush>

    <!-- 双层柔影：近影定形 + 远影飘浮 -->
    <DropShadowEffect x:Key="GlassShadowNear" BlurRadius="18" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.40"/>
    <DropShadowEffect x:Key="GlassShadowFar" BlurRadius="46" ShadowDepth="14" Direction="270" Color="#00040A" Opacity="0.34"/>

    <!-- 圆角与字体 -->
    <CornerRadius x:Key="GlassRadiusCard">16</CornerRadius>
    <CornerRadius x:Key="GlassRadiusControl">11</CornerRadius>
    <FontFamily x:Key="UiFontFamily">Segoe UI Variable Text, Segoe UI</FontFamily>
    <!-- ============ 液态玻璃材质 Token 结束 ============ -->

    <SolidColorBrush x:Key="PageBackground" Color="#0B0F18"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#202638"/>
    <SolidColorBrush x:Key="PanelStroke" Color="#333B52"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#F5F7FB"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#AEB7CB"/>
    <SolidColorBrush x:Key="TextMuted" Color="#868FA6"/>
    <SolidColorBrush x:Key="AccentBlue" Color="#6EA2FF"/>
    <SolidColorBrush x:Key="AccentCyan" Color="#5DE2FF"/>
    <SolidColorBrush x:Key="AccentOrange" Color="#FF9A5E"/>

    <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#CC28324A" Offset="0"/>
        <GradientStop Color="#C6182033" Offset="0.55"/>
        <GradientStop Color="#BE111827" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#78A8FF" Offset="0"/>
        <GradientStop Color="#4778FF" Offset="0.62"/>
        <GradientStop Color="#59D9FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PrimaryButtonHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#8DB7FF" Offset="0"/>
        <GradientStop Color="#5B89FF" Offset="0.58"/>
        <GradientStop Color="#72E5FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PrimaryButtonPressedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5E8DE8" Offset="0"/>
        <GradientStop Color="#365FD6" Offset="0.62"/>
        <GradientStop Color="#42BDE4" Offset="1"/>
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="GlowBrush" Center="0.52,0.26" GradientOrigin="0.52,0.26" RadiusX="0.8" RadiusY="0.65">
        <GradientStop Color="#355CFF" Offset="0"/>
        <GradientStop Color="#22345F" Offset="0.38"/>
        <GradientStop Color="#111827" Offset="1"/>
    </RadialGradientBrush>

    <Style x:Key="DashboardCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GlassStroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource GlassRadiusCard}"/>
        <Setter Property="Effect" Value="{StaticResource GlassShadowFar}"/>
        <Setter Property="local:GlowBorder.IsActive" Value="True"/>
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>

    <Style x:Key="StatusLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
    </Style>

    <Style x:Key="MetricCaption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="MetricValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="EmptyStateText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="18"/>
        <Setter Property="MaxWidth" Value="320"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KeyboardFocusVisual" TargetType="Control">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control">
                    <Border BorderBrush="{StaticResource AccentCyan}"
                            BorderThickness="1"
                            CornerRadius="9"
                            Opacity="0.72"
                            Margin="-3"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
